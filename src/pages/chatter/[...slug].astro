---
import { render, type CollectionEntry, getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/layout/Navbar.astro";
import ImageWrapper from "@/components/common/ImageWrapper.astro";
import BackgroundEffects from "@/components/effects/BackgroundEffects.svelte";
import Markdown from "@components/common/Markdown.astro";
import PostMetadata from "@/components/layout/PostMeta.astro";
import { commentConfig } from "@/config/commentConfig";
import Live2DWidget from "@/components/features/Live2DWidget.astro";
import SpineModel from "@/components/features/SpineModel.astro";
import { backgroundWallpaper, live2dWidgetConfig, siteConfig } from "@/config";
import { Icon } from "astro-icon/components";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";

export async function getStaticPaths() {
  const chatters = await getCollection("chatters", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  return chatters.map((c) => ({
    params: { slug: c.id },
    props: { chatter: c },
  }));
}

interface Props {
  chatter: CollectionEntry<"chatters">;
}

const { chatter } = Astro.props;
const { Content, headings } = await render(chatter);
const { remarkPluginFrontmatter } = await render(chatter);

const giscusCfg = commentConfig?.giscus;
const chatterTerm = `chatter/${chatter.id}`;

const backgroundImages = backgroundWallpaper.src;
let bgImage = "";
let bgImageMobile = "";
if (
  typeof backgroundImages === "object" &&
  backgroundImages !== null &&
  !Array.isArray(backgroundImages) &&
  "desktop" in backgroundImages
) {
  const d = backgroundImages.desktop;
  const m = backgroundImages.mobile;
  if (Array.isArray(d)) bgImage = d[Math.floor(Math.random() * d.length)];
  else if (d) bgImage = d;
  if (Array.isArray(m)) bgImageMobile = m[Math.floor(Math.random() * m.length)];
  else if (m) bgImageMobile = m;
  else bgImageMobile = bgImage;
} else if (typeof backgroundImages === "string") {
  bgImage = backgroundImages;
  bgImageMobile = backgroundImages;
}

const themeColors = ["#a18cd1", "#fbc2eb", "#a1c4fd", "#c2e9fb", "#ffecd2", "#fcb69f", "#ff9a9e", "#fad0c4"];

const stickyNavbar = siteConfig.navbar.stickyNavbar ?? false;
const navbarWidthFull = siteConfig.navbar.widthFull ?? false;

---

<Layout title={chatter.data.title} description={chatter.data.description}>
  <script is:inline>document.body.classList.add("is-standalone")</script>
  <div id="banner-overlay-container" style="display:none"></div>
  <div id="banner-dim-container" style="display:none"></div>
  <div id="left-sidebar-dynamic" style="display:none"></div>
  <div id="swup-container">

  <!-- Fixed Background Layer -->
  <div class="fixed inset-0 z-[-1] pointer-events-none overflow-hidden">
    {bgImageMobile && (
      <div class="absolute inset-0 block lg:hidden">
        <ImageWrapper
          src={bgImageMobile} alt=""
          class="!absolute !inset-0 !w-full !h-full"
          loading="eager" fetchpriority="high"
          widths={[640, 750, 1080]} sizes="100vw"
        />
      </div>
    )}
    {bgImage && (
      <div class="absolute inset-0 hidden lg:block">
        <ImageWrapper
          src={bgImage} alt=""
          class="!absolute !inset-0 !w-full !h-full"
          loading="eager" fetchpriority="high"
          widths={[1280, 1920, 2560]} sizes="100vw"
        />
      </div>
    )}
    <div class="absolute inset-0 z-[1] bg-white/30 dark:bg-slate-900/40 backdrop-blur-md transition-colors duration-1000"></div>
    <div class="absolute inset-0 z-[2] opacity-60 dark:opacity-20 mix-blend-color transition-opacity duration-1000"
      style={`background: linear-gradient(-45deg, ${themeColors.join(", ")}); background-size: 400% 400%; animation: chatterGradientMove 15s ease infinite;`}></div>
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-white/40 dark:bg-indigo-900/20 blur-[100px] rounded-full z-[3] md:mix-blend-overlay"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-indigo-400/30 dark:bg-purple-900/30 blur-[100px] rounded-full z-[3] md:mix-blend-overlay"></div>
  </div>

  <!-- 萤火虫/樱花特效 -->
  <BackgroundEffects client:load />

    <!-- Navbar -->
  <div
    id="top-row"
    class="z-50 pointer-events-none relative transition-all duration-700 mx-auto"
    class:list={[
      stickyNavbar ? "h-18 fixed top-0 left-0 right-0 z-80" : "",
      navbarWidthFull ? "" : "w-full xl:w-[92vw] max-w-(--page-width) px-0 md:px-4",
    ]}
  >
    <div
      id="navbar-wrapper"
      class:list={[
        "pointer-events-auto transition-all",
        stickyNavbar ? "" : "sticky top-0",
      ]}
    >
      <Navbar />
    </div>
  </div>

  <main class="relative z-10 min-h-screen pt-24 md:pt-28 pb-10">
    <div class="max-w-xl mx-auto px-5 md:px-8">

      <!-- Nav pills: 主页 / 归档说说 -->
      <div class="flex gap-2 mb-6">
        <a href="/chatter/" class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-xl font-medium no-underline
          text-(--btn-content) bg-[color-mix(in_srgb,var(--btn-content)_6%,transparent)]
          shadow-md shadow-(--primary)/20
          hover:text-white hover:bg-(--primary) hover:shadow-lg hover:shadow-(--primary)/30
          transition-all duration-200 ease-out">
          <Icon name="material-symbols:home" is:inline class="text-lg" />
        </a>
        <a href="/chatter/archive/" class="inline-flex items-center text-sm px-3 py-1.5 rounded-xl font-medium no-underline whitespace-nowrap
          text-(--btn-content) bg-[color-mix(in_srgb,var(--btn-content)_6%,transparent)]
          shadow-md shadow-(--primary)/20
          hover:text-white hover:bg-(--primary) hover:shadow-lg hover:shadow-(--primary)/30
          transition-all duration-200 ease-out">
          归档说说
        </a>
      </div>

      <!-- Chatter card - playful chat-bubble style -->
      <div class="relative">
        <!-- Decorative quote mark -->
        <div class="absolute -top-4 -left-3 text-6xl text-(--primary)/20 select-none pointer-events-none z-0" aria-hidden="true">&ldquo;</div>

        <div class="relative z-10 bg-white/60 dark:bg-slate-800/50 backdrop-blur-xl rounded-3xl rounded-tl-sm
          border border-white/50 dark:border-white/10
          shadow-lg shadow-(--primary)/5
          px-6 md:px-10 pt-8 pb-6 mb-4
          transition-all duration-300">

          <!-- word count and reading time - playful pills -->
          {remarkPluginFrontmatter.words != null && (
            <div class="flex flex-wrap items-center gap-2 mb-5 onload-animation">
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs
                bg-(--primary)/10 text-(--primary) font-medium">
                <Icon name="material-symbols:notes-rounded" class="text-sm" />
                {remarkPluginFrontmatter.words} {i18n(I18nKey.wordsCount)}
              </span>
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs
                bg-amber-500/10 text-amber-600 dark:text-amber-400 font-medium">
                <Icon name="material-symbols:schedule-outline-rounded" class="text-sm" />
                {remarkPluginFrontmatter.minutes} {i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount)}
              </span>
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs
                bg-pink-500/10 text-pink-600 dark:text-pink-400 font-medium">
                <Icon name="material-symbols:chat-bubble-outline-rounded" class="text-sm" />
                说说
              </span>
            </div>
          )}

          <!-- title - playful with colorful underline -->
          <div class="relative onload-animation mb-4">
            <h1
              data-pagefind-body data-pagefind-meta="title"
              class="text-2xl md:text-3xl font-bold leading-relaxed
                text-black/85 dark:text-white/90
                bg-gradient-to-r from-(--primary) via-pink-400 to-amber-400
                bg-clip-text"
            >
              {chatter.data.title}
            </h1>
            <div class="mt-2 h-1 w-20 rounded-full bg-gradient-to-r from-(--primary) via-pink-400 to-amber-400"></div>
          </div>

          <!-- metadata -->
          <div class="onload-animation mb-5">
            <PostMetadata className="mb-3" published={chatter.data.published} tags={chatter.data.tags} id={chatter.id} />
          </div>

          <!-- fun divider -->
          <div class="flex items-center gap-2 mb-5">
            <div class="flex-1 h-px bg-gradient-to-r from-transparent via-(--primary)/30 to-transparent"></div>
            <span class="text-(--primary)/40 text-xs">✦</span>
            <div class="flex-1 h-px bg-gradient-to-r from-transparent via-pink-400/30 to-transparent"></div>
          </div>

          <!-- content -->
          <Markdown class="mb-6 markdown-content onload-animation">
            <Content />
          </Markdown>

          <!-- bottom decoration -->
          <div class="flex justify-center mt-6">
            <div class="flex items-center gap-1 text-(--primary)/25 text-xs">
              <span class="h-1 w-1 rounded-full bg-(--primary)/30"></span>
              <span class="h-1 w-1 rounded-full bg-pink-400/30"></span>
              <span class="h-1 w-1 rounded-full bg-amber-400/30"></span>
            </div>
          </div>
        </div>

        <!-- Decorative quote mark (close) -->
        <div class="absolute -bottom-4 -right-3 text-6xl text-(--primary)/20 select-none pointer-events-none z-0 rotate-180" aria-hidden="true">&ldquo;</div>
      </div>

      <!-- comments with Giscus (synced with list page via specific mapping) -->
      {(chatter.data as any).comment !== false && giscusCfg && (
        <div class="mt-6" id="chatter-comments">
          <div class="flex items-center gap-3 mb-3 px-2">
            <div class="h-8 w-8 rounded-full bg-gradient-to-br from-(--primary) via-pink-400 to-amber-400 flex items-center justify-center shadow-md shadow-(--primary)/20">
              <Icon name="material-symbols:forum-outline-rounded" class="text-white text-lg" />
            </div>
            <span class="text-sm font-semibold text-black/50 dark:text-white/50">讨论</span>
            <div class="flex-1 h-px bg-gradient-to-r from-(--primary)/20 via-pink-400/20 to-transparent"></div>
          </div>

          <div class="relative bg-white/60 dark:bg-slate-800/50 backdrop-blur-xl rounded-3xl rounded-tl-sm
            border border-(--primary)/20 dark:border-(--primary)/15
            shadow-lg shadow-(--primary)/10
            px-4 md:px-8 py-5">
            <script is:inline type="module" src="https://esm.sh/giscus"></script>
            <giscus-widget
              repo={giscusCfg.repo}
              repoId={giscusCfg.repoId}
              category={giscusCfg.category}
              categoryId={giscusCfg.categoryId}
              mapping="specific"
              term={chatterTerm}
              strict={giscusCfg.strict}
              reactionsEnabled={giscusCfg.reactionsEnabled}
              emitMetadata={giscusCfg.emitMetadata}
              inputPosition="bottom"
              lang={giscusCfg.lang}
              loading={giscusCfg.loading}
            />
          </div>
        </div>
      )}

      <script is:inline>
        (function() {
          function getTheme() {
            return document.documentElement.classList.contains('dark') ? 'transparent_dark' : 'light';
          }
          function applyTheme() {
            const theme = getTheme();
            const widget = document.querySelector('#chatter-comments giscus-widget');
            if (widget) {
              if (widget.getAttribute('theme') !== theme) {
                widget.setAttribute('theme', theme);
              }
              if (widget.getAttribute('inputposition') !== 'bottom') {
                widget.setAttribute('inputposition', 'bottom');
              }
            }
          }
          const widget = document.querySelector('#chatter-comments giscus-widget');
          if (widget) widget.setAttribute('theme', getTheme());
          setTimeout(applyTheme, 1200);
          new MutationObserver(() => setTimeout(applyTheme, 150))
            .observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
        })();
      </script>
    </div>
  </main>

  <SpineModel></SpineModel>
  {live2dWidgetConfig.enable && <Live2DWidget config={live2dWidgetConfig} />}
  </div>
  <div id="right-sidebar-dynamic" style="display:none"></div>
  <div id="floating-toc-wrapper" style="display:none"></div>
</Layout>

<style is:global>
  @keyframes chatterGradientMove {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
</style>

<style>
  #chatter-comments :global(.card-base) {
    background: transparent !important;
    padding: 0 !important;
    margin-bottom: 0 !important;
    border-radius: 0;
    overflow: visible;
  }
</style>
