---
import { commentConfig } from "@/config/commentConfig";

const gitalk = commentConfig?.gitalk;
const isConfigured = gitalk &&
  gitalk.clientID &&
  gitalk.clientSecret &&
  gitalk.repo &&
  gitalk.owner &&
  gitalk.admin?.length > 0;

const proxy = gitalk?.proxy || "";
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gitalk@1/dist/gitalk.css" />

<div id="gitalk-container" class="chatter-gitalk">
  {!isConfigured && (
    <div class="text-center py-10 text-black/40 dark:text-white/30">
      <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-(--primary)/10 flex items-center justify-center">
        <svg class="w-7 h-7 text-(--primary)/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
        </svg>
      </div>
      <p class="text-sm font-medium">Gitalk 评论未配置</p>
      <p class="text-xs mt-1 opacity-70">请到 config/commentConfig.ts 中填入 GitHub OAuth App 信息</p>
    </div>
  )}
</div>

{isConfigured && (
  <script is:inline define:vars={{
    clientID: gitalk.clientID,
    clientSecret: gitalk.clientSecret,
    repo: gitalk.repo,
    owner: gitalk.owner,
    admin: JSON.stringify(gitalk.admin),
    proxy,
  }}>
    (function() {
      const container = document.getElementById('gitalk-container');
      if (!container) return;

      function loadScript(src, callback) {
        const script = document.createElement('script');
        script.src = src;
        script.async = true;
        script.onload = callback;
        document.head.appendChild(script);
      }

      function initGitalk() {
        const pathname = window.location.pathname;
        container.innerHTML = '';

        new Gitalk({
          clientID,
          clientSecret,
          repo,
          owner,
          admin: JSON.parse(admin),
          proxy: proxy || undefined,
          id: (pathname.replace(/\/$/, '') || '/').substring(0, 49),
          distractionFreeMode: false,
        }).render(container);

        const url = new URL(window.location.href);
        if (url.searchParams.has('code')) {
          url.searchParams.delete('code');
          window.history.replaceState({}, document.title, url.toString());
        }
      }

      if (window.Gitalk) {
        initGitalk();
      } else {
        loadScript('https://cdn.jsdelivr.net/npm/gitalk@1/dist/gitalk.min.js', initGitalk);
      }
    })();
  </script>
)}

<style is:global>
  .chatter-gitalk .gt-container .gt-header-textarea {
    background: rgba(255, 255, 255, 0.1) !important;
    backdrop-filter: blur(12px) !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
    border-radius: 16px !important;
    color: inherit !important;
    transition: all 0.3s ease;
    font-size: 14px !important;
    padding: 12px 16px !important;
  }
  .chatter-gitalk .gt-container .gt-header-textarea:focus {
    background: rgba(255, 255, 255, 0.2) !important;
    border-color: #a18cd1 !important;
    box-shadow: 0 0 15px rgba(161, 140, 209, 0.3) !important;
    outline: none !important;
  }
  .dark .chatter-gitalk .gt-container .gt-header-textarea {
    background: rgba(255, 255, 255, 0.05) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    color: rgba(255, 255, 255, 0.9) !important;
  }
  .dark .chatter-gitalk .gt-container .gt-header-textarea:focus {
    background: rgba(255, 255, 255, 0.1) !important;
    border-color: rgba(196, 176, 255, 0.5) !important;
  }

  .chatter-gitalk .gt-container .gt-header-preview {
    background: rgba(255, 255, 255, 0.1) !important;
    backdrop-filter: blur(12px) !important;
    border-radius: 16px !important;
  }

  .chatter-gitalk .gt-container .gt-btn {
    background: linear-gradient(135deg, rgba(161, 140, 209, 0.8), rgba(210, 160, 210, 0.7)) !important;
    border: none !important;
    border-radius: 12px !important;
    box-shadow: 0 4px 15px rgba(161, 140, 209, 0.3) !important;
    transition: all 0.2s ease;
    color: white !important;
  }
  .chatter-gitalk .gt-container .gt-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(161, 140, 209, 0.5) !important;
    opacity: 0.95;
  }

  .chatter-gitalk .gt-container .gt-comment-content {
    background: rgba(255, 255, 255, 0.05) !important;
    backdrop-filter: blur(8px) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    border-radius: 14px !important;
    transition: all 0.2s ease;
  }
  .chatter-gitalk .gt-container .gt-comment-content:hover {
    background: rgba(255, 255, 255, 0.08) !important;
  }
  .dark .chatter-gitalk .gt-container .gt-comment-content {
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.06) !important;
  }
  .dark .chatter-gitalk .gt-container .gt-comment-content:hover {
    background: rgba(255, 255, 255, 0.06) !important;
  }

  .chatter-gitalk .gt-container .gt-comment-admin .gt-comment-content {
    border-color: rgba(161, 140, 209, 0.4) !important;
  }

  .chatter-gitalk .gt-container .gt-avatar {
    border-radius: 50% !important;
    overflow: hidden;
  }

  .chatter-gitalk .gt-container .gt-comment-body {
    color: inherit !important;
  }

  .chatter-gitalk .gt-container a {
    color: #a18cd1 !important;
  }
  .dark .chatter-gitalk .gt-container a {
    color: #c4b0ff !important;
  }

  .chatter-gitalk .gt-container .gt-header-controls {
    margin-top: 8px;
  }

  .chatter-gitalk .gt-container .gt-popup {
    border-radius: 12px !important;
    backdrop-filter: blur(12px) !important;
  }
</style>
