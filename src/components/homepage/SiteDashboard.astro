---
import { siteConfig } from "@/config";
const badges = [
	{ name: "Astro", color: "text-orange-500", svg: '<path d="M12 2L2 20h7l3-7 3 7h7L12 2z"/>' },
	{ name: "Svelte", color: "text-red-500", svg: '<path d="M12 2L2 22h20L12 2zM12 6l6 14H6l6-14z"/>' },
	{ name: "Tailwind", color: "text-cyan-400", svg: '<path d="M12.001,4.8c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624C13.666,10.618,15.027,12,18.001,12c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624C16.337,6.182,14.976,4.8,12.001,4.8z M6.001,12c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624c1.177,1.194,2.538,2.576,5.512,2.576c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624C10.337,13.382,8.976,12,6.001,12z"/>' },
];
const icp = (siteConfig as any).icpConfig;
const startDateStr = siteConfig.siteStartDate || "2026-06-09";
const buildDate = startDateStr + "T00:00:00";
---

<div
	class="w-full rounded-3xl bg-white/40 dark:bg-slate-800/50 backdrop-blur-md border border-white/40 dark:border-white/10 shadow-xl overflow-hidden flex flex-col md:flex-row items-stretch transition-colors duration-700 h-auto md:h-20"
	id="site-dashboard"
>
	<!-- 左侧：翻页时钟 -->
	<div class="bg-slate-900 dark:bg-black text-white px-8 py-4 md:py-0 flex items-center justify-center font-mono text-2xl md:text-3xl font-black tracking-widest shadow-inner relative overflow-hidden shrink-0">
		<div class="absolute inset-0 bg-gradient-to-b from-white/10 to-transparent pointer-events-none"></div>
		<span id="live-clock">--:--:--</span>
		<div class="absolute left-0 right-0 top-1/2 h-px bg-black/50"></div>
	</div>

	<!-- 右侧：状态信息 -->
	<div class="flex-1 px-6 py-4 md:py-0 flex flex-wrap items-center justify-between gap-4 text-xs md:text-sm font-bold text-slate-600 dark:text-slate-300">
		<!-- 运行时间 -->
		<div class="flex items-center gap-2">
			<span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
			<span>系统已稳定运行：<span id="uptime-text" class="text-indigo-600 dark:text-indigo-400 font-black">--</span></span>
		</div>

		<!-- 技术栈徽章 -->
		<div class="flex gap-2">
			{badges.map((b) => (
				<span class="px-2 py-1 bg-white/50 dark:bg-slate-700/50 rounded-md shadow-sm flex items-center gap-1 border border-white/40 dark:border-slate-600">
					<svg class={`w-3.5 h-3.5 ${b.color}`} fill="currentColor" viewBox="0 0 24 24" set:html={b.svg}></svg>
					{b.name}
				</span>
			))}
		</div>

		<!-- 备案信息 -->
		{icp && (
			<a
				href={icp.url || '#'}
				target="_blank"
				rel="noopener noreferrer"
				class="icp-link hover:text-indigo-500 transition-colors pb-0.5"
			>
				{icp.text || icp}
			</a>
		)}
	</div>
</div>

<style>
	.icp-link {
		border-bottom: 1px dashed #94a3b8;
	}
	:global(.dark) .icp-link {
		border-bottom-color: #64748b;
	}
</style>

<script define:vars={{ buildDate }}>
	const clockEl = document.getElementById("live-clock");
	const uptimeEl = document.getElementById("uptime-text");

	function updateClock() {
		if (clockEl) {
			clockEl.textContent = new Date().toLocaleTimeString("en-US", {
				hour12: false,
				hour: "2-digit",
				minute: "2-digit",
				second: "2-digit",
			});
		}
	}

	let startDate;
	try {
		startDate = new Date(buildDate);
		if (isNaN(startDate.getTime())) startDate = new Date("2026-03-23T00:00:00");
	} catch (e) {
		startDate = new Date("2026-03-23T00:00:00");
	}

	function updateUptime() {
		if (uptimeEl) {
			const now = new Date();
			const diffMs = now.getTime() - startDate.getTime();
			const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
			const hours = Math.floor((diffMs % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
			uptimeEl.textContent = `${days}天 ${hours}小时`;
		}
	}

	updateClock();
	updateUptime();
	setInterval(() => { updateClock(); updateUptime(); }, 1000);
</script>
